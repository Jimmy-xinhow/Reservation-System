# ── Supabase ───────────────────────────────────────────────
# 專案 URL 與兩把金鑰(Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# anon key 視為公開資訊,僅後台 Auth 流程使用
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service role key 只在 server 端使用,絕不可放進 NEXT_PUBLIC_* 或 client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── 診所鎖定(本版單一診所)─────────────────────────────────
# clinics 表那一筆的 id
NEXT_PUBLIC_CLINIC_ID=00000000-0000-0000-0000-000000000000

# ── LINE ───────────────────────────────────────────────────
# Messaging API channel(後台 → Channel access token / secret)
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
# LIFF channel id(驗 ID token 用,通常為 LINE Login channel id)
LINE_LOGIN_CHANNEL_ID=your-line-login-channel-id
# 病患端 LIFF 入口(前端用)
NEXT_PUBLIC_LIFF_ID=your-liff-id

# ── Cron ───────────────────────────────────────────────────
# Vercel Cron 呼叫提醒 endpoint 時帶的密鑰
CRON_SECRET=generate-a-long-random-string
# 看診前幾小時發提醒(預設 24)
REMINDER_HOURS_BEFORE=24
# 註:Email 提醒改由後台「診所設定 → Email 看診提醒」自行填入 Resend 金鑰,不走環境變數。
# 僅「Railway cron 服務」需要:web 服務公開網址,scripts/trigger-reminders.mjs 會打它
# (或改設 CRON_TARGET_URL 指定完整 endpoint URL)
APP_URL=https://your-app.up.railway.app
